APP_NAME="Developer Landing Backend"
APP_ENV=local
DEBUG=true

HOST=0.0.0.0
PORT=8000

# CORS: список доменов через запятую. Для разработки можно оставить localhost.
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Rate limiting для POST /api/contact
CONTACT_RATE_LIMIT=5
CONTACT_RATE_WINDOW_SECONDS=60

# Файловое хранилище
DATA_DIR=data
LOG_DIR=logs

# Email
MAIL_ENABLED=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=no-reply@example.com
SITE_OWNER_EMAIL=owner@example.com

# AI: Gemini через OpenAI-compatible Chat Completions API
# Ключ можно получить в Google AI Studio.
AI_ENABLED=true
AI_PROVIDER=gemini
AI_API_KEY=
AI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
AI_MODEL=gemini-2.5-flash
AI_TIMEOUT_SECONDS=15
